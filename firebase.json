{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 }
  },
  "hosting": {
    "site": "viluresidence",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/.*/**",
      "**/node_modules/**",
      ".claude/**",
      ".git/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/vilu-website.html"
      }
    ],
    "headers": [
      {
        "source": "/{vilu-website,vilu-unified,vilu-agency-portal}.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
