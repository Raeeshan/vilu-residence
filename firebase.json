{
  "hosting": {
    "site": "viluresidence",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/.*/**",
      "**/node_modules/**",
      ".claude/**",
      ".git/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/vilu-website.html"
      }
    ],
    "headers": [
      {
        "source": "/{vilu-website,vilu-unified,vilu-agency-portal}.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
